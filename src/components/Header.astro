---
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '🏠 首頁', key: 'home' },
  { href: '/quiz', label: '🎯 心理測驗', key: 'quiz' },
  { href: '/blog', label: '📚 小知識', key: 'blog' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header>
  <a class="logo" href="/">
    <span class="logo-icon">🧠</span>
    心腦筆記
  </a>
  <nav>
    {navItems.map(item => (
      <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
    ))}
  </nav>
  <button class="hamburger" id="hamburgerBtn" aria-label="選單">
    <span></span><span></span><span></span>
  </button>
</header>

<!-- MOBILE NAV -->
<div class="mobile-nav" id="mobileNav">
  {navItems.map(item => (
    <a href={item.href}>{item.label}</a>
  ))}
</div>

<script>
  document.getElementById('hamburgerBtn')?.addEventListener('click', () => {
    document.getElementById('mobileNav')?.classList.toggle('open');
  });
</script>

<style>
  header {
    position: fixed; top: 0; left: 0; right: 0; z-index: 999;
    background: var(--paper);
    border-bottom: 3px solid var(--ink);
    box-shadow: 4px 4px 0 var(--yellow);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 24px; height: 64px;
  }

  .logo {
    font-family: 'Caveat', cursive;
    font-size: 1.8rem; font-weight: 700;
    color: var(--ink); text-decoration: none;
    display: flex; align-items: center; gap: 8px;
  }
  .logo .logo-icon { font-size: 1.6rem; }

  nav { display: flex; gap: 4px; }
  nav a {
    font-family: 'Nunito', sans-serif;
    font-size: 0.88rem; font-weight: 700;
    color: var(--ink); text-decoration: none;
    padding: 8px 14px; border-radius: 20px;
    border: 2px solid transparent;
    transition: all 0.2s;
    cursor: pointer;
  }
  nav a:hover, nav a.active {
    background: var(--yellow);
    border-color: var(--ink);
    transform: translateY(-2px);
    box-shadow: 2px 2px 0 var(--ink);
  }

  .hamburger {
    display: none; flex-direction: column; gap: 5px; cursor: pointer;
    background: none; border: none; padding: 4px;
  }
  .hamburger span {
    width: 26px; height: 3px; background: var(--ink);
    border-radius: 2px; transition: 0.3s;
  }

  .mobile-nav {
    display: none; position: fixed; top: 64px; left: 0; right: 0; z-index: 998;
    background: var(--paper); border-bottom: 3px solid var(--ink);
    flex-direction: column; padding: 16px;
    box-shadow: 0 8px 24px var(--shadow);
  }
  .mobile-nav :global(.open) { display: flex; }
  .mobile-nav a {
    font-size: 1rem; font-weight: 700; color: var(--ink);
    text-decoration: none; padding: 12px 16px;
    border-bottom: 2px dashed var(--light-gray);
    cursor: pointer;
  }
  .mobile-nav a:last-child { border-bottom: none; }

  @media (max-width: 768px) {
    header { padding: 0 16px; }
    nav { display: none; }
    .hamburger { display: flex; }
  }
</style>
