---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('blog');
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={`${article.data.title} | 🏐飛吧！學習魂`} description={article.data.summary}>
  <div id="page-article">
    <div class="article-wrapper">
      <a class="article-back" href="/blog">← 返回文章列表</a>
      <span class="article-tag" style={`color:${article.data.tagColor};background:${article.data.tagBg};`}>
        {article.data.tag}
      </span>
      <h1 class="article-title">{article.data.title}</h1>
      <div class="article-meta">
        <span>📅 {article.data.date}</span>
        <span>⏱ {article.data.readTime}閱讀</span>
      </div>
      <div class="article-body">
        <Content />
      </div>
    </div>
  </div>
</Layout>

<style>
  #page-article {
    background: var(--cream); min-height: 100vh;
    padding-top: 64px;
  }
  .article-wrapper { max-width: 720px; margin: 0 auto; padding: 48px 24px 80px; }

  .article-back {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 0.9rem; font-weight: 700; color: var(--gray);
    cursor: pointer; margin-bottom: 32px;
    border: 2px solid var(--light-gray); border-radius: 20px;
    padding: 8px 16px; background: var(--paper);
    transition: all 0.2s; text-decoration: none;
  }
  .article-back:hover { border-color: var(--ink); color: var(--ink); transform: translateX(-4px); }

  .article-tag {
    display: inline-block; font-size: 0.8rem; font-weight: 800;
    padding: 5px 14px; border-radius: 20px; border: 2px solid var(--ink);
    margin-bottom: 16px;
  }
  .article-title {
    font-family: 'Noto Serif TC', serif; font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 900; line-height: 1.4; margin-bottom: 24px;
  }
  .article-meta { display: flex; gap: 16px; font-size: 0.85rem; color: var(--gray); margin-bottom: 32px; }

  .article-body {
    background: var(--paper); border: 3px solid var(--ink);
    border-radius: 20px; padding: 36px 40px;
    box-shadow: 6px 6px 0 var(--ink); line-height: 1.85;
  }
  .article-body :global(p) { margin-bottom: 20px; font-size: 1rem; }
  .article-body :global(h3) {
    font-family: 'Caveat', cursive; font-size: 1.6rem; font-weight: 700;
    margin: 28px 0 12px; color: var(--coral);
  }
  .article-body :global(ul) { padding-left: 24px; margin-bottom: 20px; }
  .article-body :global(li) { margin-bottom: 8px; font-size: 0.97rem; }
  .article-body :global(blockquote) {
    border-left: 5px solid var(--yellow); padding: 12px 20px;
    background: rgba(255,217,74,0.15); border-radius: 0 12px 12px 0;
    margin: 20px 0; font-style: italic; color: var(--gray);
  }

  @media (max-width: 768px) {
    .article-body { padding: 24px 22px; }
  }
</style>
