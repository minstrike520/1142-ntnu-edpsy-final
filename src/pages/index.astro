---
import Layout from '../layouts/Layout.astro';
---

<Layout title="飛吧！學習魂 | 排球少年 × 學習理論的靈魂歸屬趣味測驗">
  <div id="page-home">
    <div class="hero">
      <!-- Extremely large, extremely faint text background -->
      <div class="bg-text-fly" aria-hidden="true">飛 べ</div>

      <div class="hero-badge">✨ 教心KOL小組專題</div>
      <h1>
        飛吧！<br>
        <span class="highlight">學習魂</span>！
      </h1>
      <h2 class="hero-subtitle">排球少年 × 學習理論的靈魂歸屬趣味測驗</h2>
      <p>「正因為沒有翅膀，所以人們才會尋找飛翔的辦法。」<br>只要找對了自己的球風與戰術，你也能在課業上「跳」得更高、「扣」得更準！</p>
      <div class="hero-buttons">
        <a class="btn btn-primary" href="/quiz">🎯 開始測驗</a>
        <a class="btn btn-secondary" href="/blog">📖 瀏覽文章</a>
      </div>

      <div class="scroll-worm">
        <span>繼續往下看</span>
        <div class="scroll-arrow"></div>
      </div>
    </div>

    <!-- Feature section -->
    <div class="home-features">
      <h2 class="section-title">🗂️ 網站特色</h2>
      <div class="features-grid">
        <a class="feature-card card-coral" href="/quiz">
          <div class="tape washi-top" style="background:rgba(255,112,67,0.4);"></div>
          <span class="card-tag">HOT 🔥</span>
          <span class="card-icon">🎭</span>
          <h3>學習型人格測驗</h3>
          <p>6 道情境題，找出你在《排球少年!!》中對應的角色人格！你是像影山一樣的觀察模仿者，還是像北信介一樣的日常自律者？</p>
        </a>
        <a class="feature-card card-teal" href="/blog">
          <div class="tape washi-top" style="background:rgba(38,166,154,0.4);"></div>
          <span class="card-tag">NEW 🆕</span>
          <span class="card-icon">🔬</span>
          <h3>心理學小知識</h3>
          <p>用白話文解釋認知心理學、記憶科學與學習方法，讓科學變得好懂又好用！</p>
        </a>
        <a class="feature-card" href="/quiz">
          <div class="tape washi-top" style="background:rgba(124,77,255,0.35);"></div>
          <span class="card-icon">📊</span>
          <h3>個人化結果報告</h3>
          <p>測驗結束後獲得專屬人格分析，了解你的學習優勢與盲點，以及對應的角色故事！</p>
        </a>
      </div>
    </div>
  </div>
</Layout>



<style>
  #page-home {
    background: var(--cream);
    position: relative; overflow: hidden;
    padding-top: 64px; min-height: 100vh;
  }

  .hero {
    min-height: calc(100vh - 64px);
    display: flex; flex-direction: column; justify-content: center; align-items: center;
    text-align: center; padding: 40px 24px;
    position: relative;
  }

  /* Extremely large, extremely faint text background "飛べ" */
  .bg-text-fly {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: 'Noto Serif TC', serif;
    font-weight: 900;
    font-size: clamp(12rem, 32vw, 26rem);
    color: var(--ink);
    opacity: 0.035; /* Extremely faint */
    pointer-events: none;
    user-select: none;
    z-index: 0;
    white-space: nowrap;
  }

  .hero-badge {
    display: inline-block;
    background: var(--yellow); color: var(--ink);
    font-family: 'Caveat', cursive; font-size: 1.1rem; font-weight: 700;
    padding: 6px 20px; border-radius: 30px;
    border: 3px solid var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    margin-bottom: 24px;
    animation: bounceIn 0.8s cubic-bezier(.36,.07,.19,.97);
    position: relative; z-index: 1;
  }
  @keyframes bounceIn {
    0% { transform: scale(0) rotate(-10deg); }
    60% { transform: scale(1.15) rotate(3deg); }
    100% { transform: scale(1) rotate(0); }
  }

  .hero h1 {
    font-family: 'Caveat', cursive;
    font-size: clamp(3.2rem, 10vw, 7rem);
    font-weight: 700; line-height: 1.05;
    color: var(--ink); margin-bottom: 16px;
    position: relative; z-index: 1;
    animation: slideUp 0.9s ease both 0.2s;
  }
  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .hero h1 .highlight {
    position: relative; display: inline-block;
    color: var(--coral);
  }
  .hero h1 .highlight::after {
    content: '';
    position: absolute; left: -4px; right: -4px; bottom: -4px; top: -4px;
    background: var(--yellow); z-index: -1;
    transform: rotate(-2deg);
    border-radius: 4px;
  }

  .hero-subtitle {
    font-size: clamp(1.1rem, 3vw, 1.6rem);
    font-weight: 700;
    color: var(--coral);
    margin-top: -8px;
    margin-bottom: 24px;
    font-family: 'Nunito', 'Noto Serif TC', sans-serif;
    animation: slideUp 0.9s ease both 0.3s;
    position: relative; z-index: 1;
  }

  .hero p {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    color: var(--gray); max-width: 560px; line-height: 1.7;
    margin-bottom: 36px;
    position: relative; z-index: 1;
    animation: slideUp 0.9s ease both 0.4s;
  }

  .hero-buttons {
    display: flex; gap: 16px; flex-wrap: wrap; justify-content: center;
    position: relative; z-index: 1;
    animation: slideUp 0.9s ease both 0.6s;
  }

  /* Scroll worm animation */
  .scroll-worm {
    position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    z-index: 1;
    animation: fadeInUp 1s ease both 1s;
  }
  @keyframes fadeInUp { from { opacity: 0; transform: translateX(-50%) translateY(20px); } to { opacity:1; transform: translateX(-50%) translateY(0); } }
  .scroll-worm span { font-size: 0.8rem; color: var(--gray); font-family: 'Caveat', cursive; font-size: 1rem; }
  .scroll-arrow { width: 24px; height: 24px; border-right: 3px solid var(--gray); border-bottom: 3px solid var(--gray); transform: rotate(45deg); animation: arrowBounce 1.4s ease infinite; }
  @keyframes arrowBounce { 0%,100%{transform:rotate(45deg) translateY(0);} 50%{transform:rotate(45deg) translateY(6px);} }

  /* Feature cards */
  .home-features { padding: 80px 24px; max-width: 1100px; margin: 0 auto; }
  .features-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px; margin-top: 40px;
  }
  .feature-card {
    background: var(--paper); border: 3px solid var(--ink);
    border-radius: 20px; padding: 32px 28px;
    position: relative; cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 6px 6px 0 var(--ink);
    text-decoration: none; color: var(--ink);
    display: block;
  }
  .feature-card:hover { transform: translate(-4px, -4px); box-shadow: 10px 10px 0 var(--ink); }
  .feature-card .card-icon {
    font-size: 3rem; margin-bottom: 16px; display: block;
  }
  .feature-card h3 { font-family: 'Caveat', cursive; font-size: 1.8rem; margin-bottom: 12px; }
  .feature-card p { color: var(--gray); line-height: 1.6; font-size: 0.95rem; }
  .card-tag {
    position: absolute; top: -12px; right: 20px;
    background: var(--yellow); color: var(--ink);
    font-size: 0.75rem; font-weight: 800;
    padding: 4px 12px; border-radius: 20px; border: 2px solid var(--ink);
  }
  .card-coral { border-color: var(--coral); box-shadow: 6px 6px 0 var(--coral); }
  .card-coral:hover { box-shadow: 10px 10px 0 var(--coral); }
  .card-teal { border-color: var(--teal); box-shadow: 6px 6px 0 var(--teal); }
  .card-teal:hover { box-shadow: 10px 10px 0 var(--teal); }

  /* Tape decorations */
  .tape {
    position: absolute; width: 80px; height: 28px;
    opacity: 0.7; transform: rotate(-5deg);
  }
  .washi-top {
    position: absolute; top: -3px; left: 50%; transform: translateX(-50%);
    width: 60px; height: 22px; border-radius: 4px;
    border: 2px solid var(--ink);
  }
</style>
